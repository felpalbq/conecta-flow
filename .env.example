# Copy to .env.local for local development (never commit .env.local).
# Local values come from `npx supabase status -o env` after `npx supabase start`.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Used to build password-recovery email links (auth/confirm callback).
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# Server-only — never expose with a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=

# Marco 3+ (IA) — leave unset until the agent adapter is implemented.
# OPENAI_API_KEY=

# Marco 2+ (WhatsApp) — leave unset until the Evolution API adapter is implemented.
# EVOLUTION_API_URL=
# EVOLUTION_API_KEY=
